{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Streamlit Dashboard",
            "type": "debugpy",
            "request": "launch",
            "module": "streamlit",
            "args": [
                "run",
                "${workspaceFolder}/frontend/dashboard/app.py",
                "--server.port",
                "8501"
            ],
            "jinja": true,
            "justMyCode": true,
            "cwd": "${workspaceFolder}"
        }
    ]
}
